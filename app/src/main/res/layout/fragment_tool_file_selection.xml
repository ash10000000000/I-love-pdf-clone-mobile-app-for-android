<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    tools:context=".ui.tool.ToolFileSelectionFragment">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- Toolbar -->
        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@color/surface"
            android:elevation="@dimen/elevation_app_bar"
            app:navigationIcon="@android:drawable/ic_menu_close_clear_cancel"
            app:title="?attr/title"
            app:titleTextColor="@color/on_surface" />

        <!-- Scrollable content -->
        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:fillViewport="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_horizontal"
                android:orientation="vertical"
                android:padding="@dimen/spacing_medium">

                <!-- Upload Zone Card -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/upload_zone"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="@dimen/spacing_medium"
                    app:cardBackgroundColor="@color/surface"
                    app:cardCornerRadius="@dimen/card_corner_radius"
                    app:cardElevation="@dimen/elevation_card"
                    app:strokeColor="@color/outline"
                    app:strokeWidth="@dimen/upload_zone_border_width">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_horizontal"
                        android:orientation="vertical"
                        android:padding="@dimen/spacing_large">

                        <!-- Upload Icon -->
                        <ImageView
                            android:id="@+id/iv_upload_icon"
                            android:layout_width="@dimen/upload_zone_icon_size"
                            android:layout_height="@dimen/upload_zone_icon_size"
                            android:contentDescription="Upload icon"
                            android:src="@android:drawable/stat_sys_upload"
                            app:tint="@color/primary" />

                        <!-- Select File Text -->
                        <TextView
                            android:id="@+id/tv_select_file"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/spacing_medium"
                            android:text="Select PDF file"
                            android:textAppearance="?attr/textAppearanceHeadlineSmall"
                            android:textColor="@color/on_surface" />

                        <!-- Drag and Drop Text -->
                        <TextView
                            android:id="@+id/tv_drag_drop"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/spacing_xs"
                            android:text="or drag and drop here"
                            android:textAppearance="?attr/textAppearanceBodyMedium"
                            android:textColor="@color/on_surface_variant" />

                        <!-- Select File Button -->
                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_select_file"
                            style="@style/Widget.Material3.Button.OutlinedButton"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/spacing_medium"
                            android:text="Select File" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Supported Formats Chip Row -->
                <HorizontalScrollView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="@dimen/spacing_medium"
                    android:clipToPadding="false"
                    android:scrollbars="none">

                    <com.google.android.material.chip.ChipGroup
                        android:id="@+id/chip_formats"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        app:singleLine="true" />
                </HorizontalScrollView>

                <!-- Selected Files List (for multi-file tools) -->
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rv_selected_files"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:clipToPadding="false"
                    android:visibility="gone"
                    tools:listitem="@android:layout/simple_list_item_1" />
            </LinearLayout>
        </ScrollView>
    </LinearLayout>
</androidx.coordinatorlayout.widget.CoordinatorLayout>
