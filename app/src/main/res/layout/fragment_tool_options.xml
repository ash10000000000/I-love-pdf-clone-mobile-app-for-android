<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    tools:context=".ui.tool.ToolOptionsFragment">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- Toolbar -->
        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@color/surface"
            android:elevation="@dimen/elevation_app_bar"
            app:navigationIcon="@android:drawable/ic_menu_close_clear_cancel"
            app:titleTextColor="@color/on_surface" />

        <!-- Scrollable Content -->
        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:fillViewport="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/spacing_medium">

                <!-- Summary Card -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/card_summary"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="@dimen/spacing_medium"
                    app:cardBackgroundColor="@color/surface"
                    app:cardCornerRadius="@dimen/card_corner_radius"
                    app:cardElevation="@dimen/elevation_card">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="@dimen/spacing_medium">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Selected File"
                            android:textAppearance="?attr/textAppearanceLabelLarge"
                            android:textColor="@color/on_surface_variant" />

                        <TextView
                            android:id="@+id/tv_filename"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/spacing_xs"
                            android:ellipsize="middle"
                            android:singleLine="true"
                            android:textAppearance="?attr/textAppearanceTitleMedium"
                            android:textColor="@color/on_surface"
                            android:textStyle="bold"
                            tools:text="document.pdf" />

                        <TextView
                            android:id="@+id/tv_file_info"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/spacing_xs"
                            android:textAppearance="?attr/textAppearanceBodySmall"
                            android:textColor="@color/on_surface_variant"
                            tools:text="2.4 MB - 15 pages" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Tool-Specific Options Container -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/options_container"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardBackgroundColor="@color/surface"
                    app:cardCornerRadius="@dimen/card_corner_radius"
                    app:cardElevation="@dimen/elevation_card" />
            </LinearLayout>
        </ScrollView>
    </LinearLayout>

    <!-- Process FAB -->
    <com.google.android.material.floatingactionbutton.ExtendedFloatingActionButton
        android:id="@+id/fab_process"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_margin="@dimen/spacing_medium"
        android:text="Process"
        app:icon="@android:drawable/ic_media_play" />
</androidx.coordinatorlayout.widget.CoordinatorLayout>
