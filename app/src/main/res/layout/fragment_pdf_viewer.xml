<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    tools:context=".ui.viewer.PdfViewerFragment">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- Toolbar -->
        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@color/surface"
            android:elevation="@dimen/elevation_app_bar"
            app:menu="@menu/pdf_viewer_menu"
            app:navigationIcon="@android:drawable/ic_menu_close_clear_cancel"
            app:navigationContentDescription="Back"
            app:titleTextColor="@color/on_surface" />

        <!-- PDF Pages ViewPager2 -->
        <androidx.viewpager2.widget.ViewPager2
            android:id="@+id/vp_pages"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1" />
    </LinearLayout>

    <!-- Floating Page Indicator Chip -->
    <com.google.android.material.chip.Chip
        android:id="@+id/tv_page_indicator"
        style="@style/Widget.Material3.Chip.Assist.Elevated"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|center_horizontal"
        android:layout_marginBottom="@dimen/spacing_large"
        android:text="3 / 12"
        app:chipBackgroundColor="@color/surface" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>
