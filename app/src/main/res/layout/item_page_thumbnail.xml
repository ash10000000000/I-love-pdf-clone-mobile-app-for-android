<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/card_thumbnail"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:layout_margin="@dimen/spacing_xs"
    android:clickable="true"
    android:focusable="true"
    app:cardBackgroundColor="@color/surface"
    app:cardCornerRadius="@dimen/tool_item_corner_radius"
    app:cardElevation="@dimen/elevation_card">

    <FrameLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content">

        <!-- Page Thumbnail -->
        <ImageView
            android:id="@+id/iv_thumbnail"
            android:layout_width="@dimen/page_thumbnail_width"
            android:layout_height="@dimen/page_thumbnail_height"
            android:contentDescription="Page thumbnail"
            android:scaleType="centerCrop"
            tools:src="@android:drawable/ic_menu_gallery" />

        <!-- CheckBox Overlay -->
        <com.google.android.material.checkbox.MaterialCheckBox
            android:id="@+id/cb_select"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="top|start"
            android:layout_margin="@dimen/spacing_xs" />

        <!-- Rotate Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_rotate"
            style="@style/Widget.Material3.Button.IconButton.Filled.Tonal"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom|end"
            android:layout_margin="@dimen/spacing_xs"
            android:contentDescription="Rotate page"
            app:icon="@android:drawable/ic_menu_rotate" />
    </FrameLayout>
</com.google.android.material.card.MaterialCardView>
